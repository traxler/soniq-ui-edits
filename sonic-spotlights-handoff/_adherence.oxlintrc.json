{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/app/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Figtree|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Figtree, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|size|shape|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, name, size, shape, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<Avatar> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, dot, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|voice|positive|inferred|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'voice' | 'positive' | 'inferred' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|disabled|iconLeft|iconRight|type|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, disabled, iconLeft, iconRight, type, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:raised|interactive|accent|padding|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: raised, interactive, accent, padding, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|voice|positive)$/]",
        "message": "<Card> accent must be one of 'none' | 'voice' | 'positive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, disabled, label, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfidenceMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|showLabel|state|size|style|key|ref|className|style|children)$/]",
        "message": "<ConfidenceMeter> doesn't accept that prop. Declared props: value, label, showLabel, state, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfidenceMeter'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:scored|muted|nodata|error)$/]",
        "message": "<ConfidenceMeter> state must be one of 'scored' | 'muted' | 'nodata' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|label|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, disabled, label, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|voice|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'voice' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|status|helper|size|iconLeft|disabled|value|defaultValue|placeholder|onChange|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, status, helper, size, iconLeft, disabled, value, defaultValue, placeholder, onChange, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:error|success|inferred)$/]",
        "message": "<Input> status must be one of 'error' | 'success' | 'inferred'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SoniqActivityEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:h|m|key|ref|className|style|children)$/]",
        "message": "<SoniqActivityEvent> doesn't accept that prop. Declared props: h, m."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReasoningNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|citation|title|children|style|key|ref|className|style|children)$/]",
        "message": "<ReasoningNote> doesn't accept that prop. Declared props: tone, citation, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReasoningNote'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:voice|inferred)$/]",
        "message": "<ReasoningNote> tone must be one of 'voice' | 'inferred'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotlightsAtmosphere'] > JSXAttribute > JSXIdentifier[name!=/^(?:intensity|grain|style|key|ref|className|style|children)$/]",
        "message": "<SpotlightsAtmosphere> doesn't accept that prop. Declared props: intensity, grain, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|live|pulse|size|label|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: tone, live, pulse, size, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|positive|voice|inferred|danger)$/]",
        "message": "<StatusDot> tone must be one of 'neutral' | 'positive' | 'voice' | 'inferred' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|id|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, label, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onRemove|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: active, onRemove, onClick, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
